# AWS Bedrock (uses default credential chain: env vars, ~/.aws, or Lambda role)
#
# Region for the Bedrock client (highest → lowest priority):
#   BEDROCK_REGION  →  AWS_REGION (set automatically in Lambda)  →  DEFAULT_AWS_REGION  →  us-east-1
#
# On Lambda in eu-west-1: do NOT set DEFAULT_AWS_REGION=us-east-1 if you use eu.* inference
# profiles — Bedrock will reject the model id. Remove DEFAULT_AWS_REGION or set BEDROCK_REGION=eu-west-1.
# BEDROCK_REGION=eu-west-1
# DEFAULT_AWS_REGION=us-east-1

# Inference profile ID — must be an exact ID from Bedrock (Console → Inference profiles).
#
# WRONG: global.amazon.nova-lite-v1:0  (this combination does not exist)
# OK:    global.amazon.nova-2-lite-v1:0   (Nova 2 Lite, global profile)
# OK:    eu.amazon.nova-lite-v1:0         (Nova Lite v1 in EU — good for Lambda in eu-west-1)
# OK:    us.amazon.nova-lite-v1:0         (Nova Lite v1 in US regions)
#
# BEDROCK_MODEL_ID=eu.amazon.nova-2-lite-v1:0

# Optional: CORS Origins (defaults to http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: AWS S3 Configuration
USE_S3=false
S3_BUCKET=your-bucket-name

# Optional: Memory directory path
MEMORY_DIR=../memory

# Optional: HTTP port for `python server.py` (default 8000). Use if 8000 is already in use.
# PORT=8001
